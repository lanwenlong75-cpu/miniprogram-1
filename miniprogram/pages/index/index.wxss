/** index.wxss **/
/* T2: 基础交互态样式，精细布局和暖色调留到 T3 */

.page-wrap {
  padding: 30rpx;
  padding-bottom: 140rpx;
}

/* Header */
.header {
  margin-bottom: 40rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: #999;
}

/* Section */
.section {
  margin-bottom: 36rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

/* Tag Cloud */
.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* Tag — unselected state */
.tag {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #fff;
  border: 2rpx solid #e5e5e5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
}

/* Tag — selected state */
.tag-selected {
  background: #f0f8ff;
  border-color: #4a90d9;
  color: #4a90d9;
}

.tag-icon {
  margin-right: 8rpx;
  font-size: 30rpx;
}

/* More Section — collapse toggle */
.more-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.more-arrow {
  font-size: 36rpx;
  color: #999;
  transition: transform 0.2s;
}

.more-arrow-up {
  transform: rotate(90deg);
}

.more-hidden {
  display: none;
}

/* Manual Input */
.input-field {
  background: #fff;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

/* Selected Ingredients */
.selected-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.selected-tag {
  display: flex;
  align-items: center;
  background: #f0f8ff;
  border: 2rpx solid #4a90d9;
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  font-size: 28rpx;
  color: #4a90d9;
}

.selected-remove {
  margin-left: 8rpx;
  font-size: 24rpx;
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #f6f6f6;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.search-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}

.btn-disabled {
  background: #d8d8d8;
  color: #999;
}

.btn-enabled {
  background: #4a90d9;
  color: #fff;
}
