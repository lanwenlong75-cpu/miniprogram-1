/** index.wxss **/
/* T3: 暖色调首页布局 —— 暖白背景 + 暖橙主色 + 深棕灰文字 */

/* ── 色板 ── */
/* 背景: #FFF8F0 暖白      */
/* 主色: #FF8C42 暖橙      */
/* 文字: #4A3B32 深棕灰    */
/* 辅色: #8C7A6B 中棕      */
/* 分割: #EDE6DD 暖灰      */

.page-wrap {
  padding: 0 32rpx 160rpx;
  background: #FFF8F0;
  min-height: 100vh;
}

/* ── Header / 标题区 (3.2) ── */
.header {
  padding-top: 48rpx;
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #4A3B32;
  line-height: 1.3;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: #8C7A6B;
  line-height: 1.5;
  letter-spacing: 1rpx;
}

/* ── Section 区块 (3.4) ── */
.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5C4F43;
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

.tag-group-title {
  font-size: 26rpx;
  color: #8C7A6B;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

/* ── Tag Cloud / 标签云 (3.3) ── */
.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* Tag — 未选中 */
.tag {
  display: flex;
  align-items: center;
  padding: 14rpx 28rpx;
  background: #F5EDE0;
  border: 2rpx solid #EDE6DD;
  border-radius: 44rpx;
  font-size: 28rpx;
  color: #6B5D52;
  transition: all 0.2s ease;
}

/* Tag — 选中态：暖橙填充 + 深棕灰文字（WCAG AA 4.63:1） */
.tag-selected {
  background: #FF8C42;
  border-color: #FF8C42;
  color: #4A3B32;
  font-weight: 500;
}

.tag-icon {
  margin-right: 8rpx;
  font-size: 30rpx;
}

/* ── Manual Input (3.4) ── */
.input-field {
  background: #FFFFFF;
  border: 2rpx solid #EDE6DD;
  border-radius: 16rpx;
  padding: 22rpx 28rpx;
  font-size: 28rpx;
  color: #4A3B32;
  width: 100%;
  height: 80rpx;
  line-height: normal;
  box-sizing: border-box;
}

.input-field::placeholder {
  color: #B5A89C;
}

/* ── Selected Ingredients / 已选食材区 ── */
.selected-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.selected-tag {
  display: flex;
  align-items: center;
  background: #FFF0E0;
  border: 2rpx solid #FF8C42;
  border-radius: 44rpx;
  padding: 14rpx 28rpx;
  font-size: 28rpx;
  color: #4A3B32;
  font-weight: 500;
}

.selected-remove {
  margin-left: 10rpx;
  font-size: 22rpx;
  color: #B58A6B;
  opacity: 0.7;
}

/* ── Bottom Bar / 底部固定按钮 (3.5) ── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, #FFF8F0 60%, rgba(255, 248, 240, 0));
  pointer-events: none;
}

.search-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: 4rpx;
  pointer-events: auto;
}

.btn-disabled {
  background: #E0D8CF;
  color: #B5A89C;
}

.btn-enabled {
  background: linear-gradient(135deg, #FF9A4A 0%, #FF7A22 100%);
  color: #FFFFFF;
  box-shadow: 0 6rpx 20rpx rgba(255, 140, 66, 0.35);
}
