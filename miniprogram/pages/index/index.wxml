<wxs module="utils">
var includes = function(list, name) {
  for (var i = 0; i < list.length; i++) {
    if (list[i].name === name) return true;
  }
  return false;
}
module.exports.includes = includes;
</wxs>

<view class="page-wrap">
  <!-- Header -->
  <view class="header">
    <view class="header-title">有什么做什么</view>
    <view class="header-subtitle">输入冰箱里的食材，看看能做什么菜</view>
  </view>

  <!-- Tag Groups by Category -->
  <view class="section" wx:for="{{tagGroups}}" wx:for-item="group" wx:key="group.key">
    <view class="tag-group-title">{{group.title}}</view>
    <view class="tag-cloud">
      <view
        wx:for="{{group.tags}}"
        wx:key="name"
        class="tag {{utils.includes(selectedIngredients, item.name) ? 'tag-selected' : ''}}"
        data-name="{{item.name}}"
        data-icon="{{item.icon}}"
        bindtap="toggleTag"
      >
        <text class="tag-icon">{{item.icon}}</text>
        <text class="tag-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- Manual Input -->
  <view class="section">
    <view class="section-title">手动添加</view>
    <input
      class="input-field"
      placeholder="输入食材名称，如：牛肉"
      value="{{inputValue}}"
      bindinput="onInputChange"
      bindconfirm="onInputConfirm"
      confirm-type="done"
    />
  </view>

  <!-- Selected Ingredients -->
  <view class="section" wx:if="{{selectedIngredients.length > 0}}">
    <view class="section-title">已选食材（{{selectedIngredients.length}}）</view>
    <view class="selected-list">
      <view
        wx:for="{{selectedIngredients}}"
        wx:key="name"
        class="selected-tag"
        data-name="{{item.name}}"
        bindtap="removeIngredient"
      >
        <text wx:if="{{item.icon}}">{{item.icon}} </text>
        <text>{{item.name}}</text>
        <text class="selected-remove"> ✕</text>
      </view>
    </view>
  </view>

  <!-- Bottom Search Button -->
  <view class="bottom-bar">
    <button
      class="search-btn {{selectedIngredients.length === 0 ? 'btn-disabled' : 'btn-enabled'}}"
      disabled="{{selectedIngredients.length === 0}}"
      bindtap="onSearchRecipes"
    >
      查找菜谱
    </button>
  </view>
</view>
