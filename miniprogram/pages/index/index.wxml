<view class="page-wrap">
  <!-- Header -->
  <view class="header">
    <view class="header-title">冰箱有什么？</view>
    <view class="header-subtitle">选择食材，秒出菜谱</view>
  </view>

  <!-- Frequent Tags Cloud -->
  <view class="section">
    <view class="section-title">常用食材</view>
    <view class="tag-cloud">
      <view
        wx:for="{{frequentTags}}"
        wx:key="name"
        class="tag {{selectedIngredients.some(i => i.name === item.name) ? 'tag-selected' : ''}}"
        data-name="{{item.name}}"
        data-icon="{{item.icon}}"
        bindtap="toggleTag"
      >
        <text class="tag-icon">{{item.icon}}</text>
        <text class="tag-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- More Ingredients (Collapsible) -->
  <view class="section">
    <view class="section-title more-title" bindtap="toggleMore">
      <text>更多食材</text>
      <text class="more-arrow {{showMore ? 'more-arrow-up' : ''}}">›</text>
    </view>
    <view class="tag-cloud {{showMore ? '' : 'more-hidden'}}">
      <view
        wx:for="{{moreTags}}"
        wx:key="name"
        class="tag {{selectedIngredients.some(i => i.name === item.name) ? 'tag-selected' : ''}}"
        data-name="{{item.name}}"
        data-icon="{{item.icon}}"
        bindtap="toggleTag"
      >
        <text class="tag-icon">{{item.icon}}</text>
        <text class="tag-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- Manual Input -->
  <view class="section">
    <view class="section-title">手动添加</view>
    <input
      class="input-field"
      placeholder="输入食材名称，如：牛肉"
      value="{{inputValue}}"
      bindinput="onInputChange"
      bindconfirm="onInputConfirm"
      confirm-type="done"
    />
  </view>

  <!-- Selected Ingredients -->
  <view class="section" wx:if="{{selectedIngredients.length > 0}}">
    <view class="section-title">已选食材（{{selectedIngredients.length}}）</view>
    <view class="selected-list">
      <view
        wx:for="{{selectedIngredients}}"
        wx:key="name"
        class="selected-tag"
        data-name="{{item.name}}"
        bindtap="removeIngredient"
      >
        <text wx:if="{{item.icon}}">{{item.icon}} </text>
        <text>{{item.name}}</text>
        <text class="selected-remove"> ✕</text>
      </view>
    </view>
  </view>

  <!-- Bottom Search Button -->
  <view class="bottom-bar">
    <button
      class="search-btn {{selectedIngredients.length === 0 ? 'btn-disabled' : 'btn-enabled'}}"
      disabled="{{selectedIngredients.length === 0}}"
    >
      查找菜谱
    </button>
  </view>
</view>
